# ============================================
# DeepSeek API (Primary LLM / 主要模型)
# ============================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# Optional: OpenAI fallback (备用模型)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================
# Embedding model for RAG (向量检索 Embedding 模型)
# Requires 1024-dim FAISS indices built by:
#   python scripts/build_psychology_vectorstores.py
# ============================================
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ============================================
# Vector store path (向量库路径)
# Relative to this project's parent directory
# ============================================
KNOWLEDGE_DIR=../knowledge/vector_stores

# ============================================
# Logging (日志)
# ============================================
LOG_LEVEL=INFO
DEBUG=false
